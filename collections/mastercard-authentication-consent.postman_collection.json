          "name": "Get consent languages",
          "request": {
            "name": "Get consent languages",
            "description": {
              "content": "Get the consent language text for enrolled service(s). A merchant/psp can use this API to get the text for their enrollment and cache it for later use.",
              "type": "text/plain"
            },
            "url": {
              "path": [
                "consent-languages"
              ],
              "host": [
                "{{baseUrl}}"
              ],
              "query": [
                {
                  "disabled": false,
                  "key": "locale",
                  "value": "<string>",
                  "description": "Locale of the requested consent language. An optional field, if not passed then en-US will be used."
                },
                {
                  "disabled": false,
                  "key": "consent_types",
                  "value": "<string>",
                  "description": "List of Consent Type for different services. An optional query parameter, if not provided then all type of consent languages will be returned in the response <br/>Possible values are INDIA_FRICTIONLESS, DEVICE_AUTH and FRICTIONLESS_DEVICE_AUTH <br/>Multiple values can be sent in the request in order to receive multiple consents in response."
